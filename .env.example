NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# TrueLayer Data API (server-only; OAuth + account/transaction reads — not Payments)
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
TRUELAYER_REDIRECT_URI=https://your-app.example.com/api/truelayer/callback
# Data API v1 base: must match TRUELAYER_MODE (live vs sandbox in Console)
TRUELAYER_BASE_URL=https://api.truelayer.com/data/v1
TRUELAYER_MODE=live
