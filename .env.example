NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TrueLayer Data API (server-only; OAuth + account/transaction reads — not Payments)
#
# Use ONE paired set: sandbox OR live. Mixing (e.g. sandbox client_id + live TRUELAYER_MODE)
# causes TrueLayer to show "Invalid client_id" on the authorize page.
#
# --- Sandbox (default for new Console apps; client_id starts with sandbox-) ---
# TRUELAYER_CLIENT_ID=sandbox-yourid
# TRUELAYER_CLIENT_SECRET=your-sandbox-secret
# TRUELAYER_REDIRECT_URI=http://localhost:3000/api/truelayer/callback
# TRUELAYER_BASE_URL=https://api.truelayer-sandbox.com/data/v1
# TRUELAYER_MODE=sandbox
#
# --- Live (production; client_id does NOT start with sandbox-) ---
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
# Must match a redirect URI registered in TrueLayer Console for this client (exact string, incl. scheme).
# Production: https://your-domain.com/api/truelayer/callback
# Local: register http://localhost:3000/api/truelayer/callback in Console, then:
TRUELAYER_REDIRECT_URI=http://localhost:3000/api/truelayer/callback
TRUELAYER_BASE_URL=https://api.truelayer.com/data/v1
TRUELAYER_MODE=live
