NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: AI auto-categorisation (npm packages: ai, @ai-sdk/openai). Server-only; if unset, rule-based categorisation only.
# Uses Chat Completions (not OpenAI Responses API). Restricted keys must allow chat/completions; if you still see scope errors, enable Model capabilities for the key in OpenAI dashboard.
OPENAI_API_KEY=your-openai-api-key
# Optional: model id (default gpt-4o-mini).
# AI_CATEGORIZE_MODEL=gpt-4o-mini
# Optional: max transactions sent to the model per run (default 500). Use 0 for no limit.
# AI_CATEGORIZE_MAX_TRANSACTIONS=500
# Optional: send transaction notes to OpenAI (default off; privacy). Set to true/1/yes to enable.
# AI_CATEGORIZE_INCLUDE_TRANSACTION_NOTES=false

# In Supabase Dashboard → Authentication → Providers → Email: enable “Leaked password protection” (HaveIBeenPwned) for safer signups/logins.

# Vercel Cron: protects GET /api/truelayer/cron-sync (Bearer token).
# In Vercel, set CRON_SECRET in Project Settings; Vercel sends Authorization: Bearer <CRON_SECRET> on cron invocations.
# Use at least 16 characters (Vercel recommendation); the route rejects shorter values.
CRON_SECRET=generate-a-long-random-secret-at-least-16-chars

# Optional tuning for scheduled bank sync (defaults shown in lib/truelayer/cron-sync.ts)
# BANK_SYNC_CRON_BATCH_SIZE=8
# BANK_SYNC_LEASE_SECONDS=900
# BANK_SYNC_INTERVAL_MINUTES=30
# BANK_SYNC_BACKOFF_BASE_SECONDS=300
# BANK_SYNC_CRON_TRANSACTION_DAYS=7
# BANK_SYNC_INTER_USER_DELAY_MS=0

# TrueLayer Data API (server-only; OAuth + account/transaction reads — not Payments)
#
# Use ONE paired set: sandbox OR live. Mixing (e.g. sandbox client_id + live TRUELAYER_MODE)
# causes TrueLayer to show "Invalid client_id" on the authorize page.
#
# --- Sandbox (default for new Console apps; client_id starts with sandbox-) ---
# TRUELAYER_CLIENT_ID=sandbox-yourid
# TRUELAYER_CLIENT_SECRET=your-sandbox-secret
# TRUELAYER_REDIRECT_URI=http://localhost:3000/api/truelayer/callback
# TRUELAYER_BASE_URL=https://api.truelayer-sandbox.com/data/v1
# TRUELAYER_MODE=sandbox
#
# --- Live (production; client_id does NOT start with sandbox-) ---
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
# Must match a redirect URI registered in TrueLayer Console for this client (exact string, incl. scheme).
# Production: https://your-domain.com/api/truelayer/callback
# Local: register http://localhost:3000/api/truelayer/callback in Console, then:
TRUELAYER_REDIRECT_URI=http://localhost:3000/api/truelayer/callback
TRUELAYER_BASE_URL=https://api.truelayer.com/data/v1
TRUELAYER_MODE=live
